# Local-first defaults. setup.py copies this file to frontend/.env.local and
# backend/.env (only when they don't exist yet).
#
# Local Supabase: `supabase start` prints the local anon key — paste it into
# NEXT_PUBLIC_SUPABASE_ANON_KEY in frontend/.env.local (`supabase status`
# re-prints it any time). For production values see references in the repo
# README / deploy docs.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
BACKEND_URL=http://localhost:8080
